{
  "name": "dashboard-runner-app",
  "version": "1.0.1",
  "description": "Cross-platform local runner for Next.js dashboard apps",
  "main": "src/main.js",
  "author": "Zach Waits",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64",
    "build:win:portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "electron": "^31.6.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lawyer.dashboardrunner",
    "productName": "Dashboard Runner",
    "afterSign": "scripts/after-sign.js",
    "directories": {
      "buildResources": "src/assets",
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": true,
      "entitlements": "scripts/entitlements.mac.plist",
      "entitlementsInherit": "scripts/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "zwaits",
      "repo": "Runner-App"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
