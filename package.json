{
  "name": "dashboard-runner-app",
  "version": "1.0.0",
  "description": "Cross-platform local runner for Next.js dashboard apps",
  "main": "src/main.js",
  "author": "Zach Waits",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64",
    "build:win:portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^31.6.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lawyer.dashboardrunner",
    "productName": "Dashboard Runner",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "src/assets",
      "output": "dist"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
